{
  "name": "@justlend/mcp-server-justlend",
  "version": "1.0.4",
  "description": "MCP server for JustLend V1 DAO on TRON blockchain. Supports supply, borrow, repay, withdraw, market data, mining rewards (USDD/WBTC), API integration, general TRON chain utilities, and AI-guided DeFi prompts.",
  "type": "module",
  "module": "src/index.ts",
  "main": "build/index.js",
  "bin": {
    "mcp-server-justlend": "./bin/cli.js"
  },
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start:http": "tsx src/server/http-server.ts",
    "dev:http": "tsx watch src/server/http-server.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@bankofai/agent-wallet": "2.3.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "cors": "2.8.6",
    "express": "4.22.1",
    "open": "11.0.0",
    "tronlink-signer": "0.1.1",
    "tronweb": "6.2.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.19.15",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "overrides": {
    "axios": "1.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tron",
    "justlend",
    "defi",
    "lending",
    "borrowing",
    "ai",
    "agent",
    "jtoken"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justlend/mcp-server-justlend.git"
  },
  "homepage": "https://github.com/justlend/mcp-server-justlend#readme",
  "bugs": {
    "url": "https://github.com/justlend/mcp-server-justlend/issues"
  },
  "license": "MIT"
}
